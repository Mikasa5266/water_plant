{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://water-plant.local/contracts/simulation-events.schema.json",
  "title": "SimulationEvent",
  "type": "object",
  "required": ["id", "type", "targetId", "timestamp"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "device.status.changed",
        "flow.started",
        "flow.stopped",
        "alert.highlighted",
        "camera.focused",
        "maintenance.previewed"
      ]
    },
    "targetId": {
      "type": "string",
      "description": "Stable device or 3D scene node ID."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["idle", "running", "warning", "fault", "maintenance"]
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
